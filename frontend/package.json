{
  "name": "ragchatbot-frontend",
  "version": "1.0.0",
  "description": "Frontend for RAG Chatbot",
  "scripts": {
    "format": "prettier --write \"**/*.{js,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,html,css}\"",
    "lint": "eslint script.js",
    "lint:fix": "eslint --fix script.js",
    "check": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  }
}
